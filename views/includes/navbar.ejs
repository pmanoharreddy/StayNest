<nav class="navbar">

    <!-- Logo -->
    <div class="logo">
        <a href="/listings">
            <i class="fa-regular fa-compass"></i>
        </a>
    </div>

    <!-- Left Navigation -->
    <ul class="nav-links">
        <li><a href="/listings">Explore</a></li>
        <li><a href="/listings/new">Add New Listing</a></li>
    </ul>

    <!-- Search -->
    <form class="search-form" action="/listings" method="GET">
        <input
            type="text"
            name="search"
            placeholder="Search destinations..."
            value="<%= typeof search !== 'undefined' ? search : '' %>">

        <button type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </form>

    <!-- Authentication -->
    <ul class="auth-links">
        <% if(!currUser){ %>
            <li><a href="/signup">Sign Up</a></li>
            <li><a href="/login" class="login-btn">Login</a></li>
        <% } else { %>
            <li><a href="/logout" class="login-btn">Logout</a></li>
        <% } %>
    </ul>

    <!-- Mobile Menu Button -->
    <div class="menu-btn" id="menuBtn">
        <i class="fa-solid fa-bars"></i>
    </div>

</nav>

<!-- Mobile Menu -->

<div class="mobile-menu" id="mobileMenu">

    <ul>
        <li><a href="/listings">Explore</a></li>

        <li>
            <a href="/listings/new">Add New Listing</a>
        </li>
    </ul>

    <form class="mobile-search" action="/listings" method="GET">

        <input
            type="text"
            name="search"
            placeholder="Search destinations..."
            value="<%= typeof search !== 'undefined' ? search : '' %>">

        <button type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>

    </form>

    <ul>

        <% if(!currUser){ %>

            <li><a href="/signup">Sign Up</a></li>

            <li>
                <a href="/login" class="login-btn">
                    Login
                </a>
            </li>

        <% } else { %>

            <li>
                <a href="/logout" class="login-btn">
                    Logout
                </a>
            </li>

        <% } %>

    </ul>

</div>